{
  "name": "money-management",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "next dev apps/web",
    "dev:bot": "tsx apps/bot/src/index.ts",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace @money/web",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "date-fns": "^4.1.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "telegraf": "^4.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
